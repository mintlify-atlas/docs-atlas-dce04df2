  "keyFeatures": [
    "Real-time multiplayer with WebSocket networking at 20 Hz tick rate",
    "Grid-based isometric movement with smooth visual interpolation",
    "Server-authoritative combat with melee and ranged attacks",
    "RuneScape-style XP and leveling system",
    "Lua-scripted quest system with dialogue and objectives",
    "Inventory management with equipment and combat bonuses",
    "NPC AI with state machine behaviors (idle, chase, attack)",
    "Chunk-based world streaming with Tiled map editor support",
    "Cross-platform support (native desktop and WASM)"
  ],
  "publicApiSurface": [
    "GameRoom::tick - Main game loop executing at 20 Hz",
    "GameRoom::handle_move - Server-side movement validation",
    "GameRoom::handle_attack - Combat resolution and damage calculation",
    "NetworkClient - Client-side WebSocket connection manager",
    "protocol::encode_server_message - MessagePack encoding for server messages",
    "protocol::decode_client_message - MessagePack decoding for client input",
    "NpcAI::update - NPC behavior state machine",
    "Inventory - Item management and equipment system",
    "QuestRegistry - Lua quest script loader and executor",
    "Database::save_player - Player data persistence",
    "Renderer::draw_isometric - Isometric rendering with depth sorting"
  ]
}
